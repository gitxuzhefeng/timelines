{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeLens",
  "version": "0.3.1",
  "identifier": "com.timelens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeLens",
        "width": 1120,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.timelens/**", "$USERPROFILE/.timelens/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": {
        "NSScreenCaptureUsageDescription": "TimeLens 需要屏幕录制权限以进行会话截图与活动记录。",
        "NSAccessibilityUsageDescription": "TimeLens 需要辅助功能权限以读取当前窗口标题并进行前台应用追踪。"
      }
    }
  }
}
