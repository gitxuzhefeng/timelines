{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeLens",
  "version": "0.7.0",
  "identifier": "com.timelens.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeLens",
        "width": 1120,
        "height": 720,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "shadow": false,
        "additionalBrowserArgs": "--disable-features=CalculateNativeWinOcclusion --disable-renderer-backgrounding"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.timelens/**", "$USERPROFILE/.timelens/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "TimeLens Developer"
    }
  }
}
